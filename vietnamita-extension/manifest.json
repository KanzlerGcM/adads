{
  "manifest_version": 3,
  "name": "📚 Vietnamita — Vocabulário",
  "version": "1.0",
  "description": "Overlay de vocabulário vietnamita em qualquer página. Ctrl+Shift+V para abrir/fechar.",
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Abrir/fechar vocabulário (Ctrl+Shift+V)"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
